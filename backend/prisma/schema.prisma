generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  SERVEUR
  GERANT
}

enum OrderStatus {
  EN_ATTENTE
  ACCEPTEE
  EN_PREPARATION
  PRETE
  SERVIE
  PAYEE
}

enum PaymentStatus {
  EN_ATTENTE
  EFFECTUE
  ECHOUE
  REMBOURSE
}

enum ReservationStatus {
  EN_ATTENTE
  CONFIRMEE
  ANNULEE
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  email     String   @unique
  motDePasse String
  telephone String?
  role      Role     @default(CLIENT)
  adresse   String?
  matricule String?

  clientOrders   Order[]       @relation("ClientOrders")
  serveurOrders  Order[]       @relation("ServeurOrders")
  reservations   Reservation[]
  reviews        Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id   Int    @id @default(autoincrement())
  nom  String @unique

  products Product[]

  @@map("categories")
}

model Product {
  id           Int     @id @default(autoincrement())
  nom          String
  description  String?
  prix         Float
  disponibilite Boolean @default(true)
  imageUrl     String?
  categoryId   Int

  category    Category     @relation(fields: [categoryId], references: [id])
  orderLines  OrderLine[]
  reviews     Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model Order {
  id           Int         @id @default(autoincrement())
  dateCommande DateTime    @default(now())
  statut       OrderStatus @default(EN_ATTENTE)
  montantTotal Float       @default(0)
  clientId     Int
  serveurId    Int?

  client      User      @relation("ClientOrders", fields: [clientId], references: [id])
  serveur     User?     @relation("ServeurOrders", fields: [serveurId], references: [id])
  orderLines  OrderLine[]
  payment     Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model OrderLine {
  id          Int   @id @default(autoincrement())
  quantite    Int   @default(1)
  prixUnitaire Float
  commandeId  Int
  produitId   Int

  commande Order   @relation(fields: [commandeId], references: [id])
  produit  Product @relation(fields: [produitId], references: [id])

  @@map("order_lines")
}

model Payment {
  id           Int            @id @default(autoincrement())
  montant      Float
  modePaiement String
  datePaiement DateTime       @default(now())
  statut       PaymentStatus  @default(EN_ATTENTE)
  commandeId   Int            @unique

  commande Order @relation(fields: [commandeId], references: [id])

  @@map("payments")
}

model Reservation {
  id              Int                @id @default(autoincrement())
  date            DateTime
  heure           String
  nombrePersonnes Int
  statut          ReservationStatus  @default(EN_ATTENTE)
  clientId        Int

  client User @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reservations")
}

model Review {
  id         Int      @id @default(autoincrement())
  note       Int
  commentaire String?
  dateAvis   DateTime @default(now())
  clientId   Int
  produitId  Int

  client  User    @relation(fields: [clientId], references: [id])
  produit Product @relation(fields: [produitId], references: [id])

  @@unique([clientId, produitId])

  @@map("reviews")
}

model Promotion {
  id          Int      @id @default(autoincrement())
  description String
  type        String
  valeur      Float
  dateDebut   DateTime
  dateFin     DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("promotions")
}
